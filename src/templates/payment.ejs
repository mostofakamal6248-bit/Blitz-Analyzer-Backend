<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Payment Successful - Blitz Analyzer</title>

  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f4f7fb;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    }

    .container {
      max-width: 600px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e2e8f0;
    }

    /* Header */
    .header {
      padding: 24px;
      text-align: center;
      border-bottom: 1px solid #e2e8f0;
    }

    .brand {
      font-size: 20px;
      font-weight: 700;
      color: #0f172a;
    }

    .tagline {
      font-size: 12px;
      color: #64748b;
      margin-top: 4px;
    }

    /* Content */
    .content {
      padding: 30px;
      color: #334155;
    }

    .success-badge {
      display: inline-block;
      background: #ecfdf5;
      color: #16a34a;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 10px;
      border-radius: 999px;
      margin-bottom: 15px;
    }

    h2 {
      margin: 0 0 10px;
      font-size: 22px;
      color: #0f172a;
    }

    p {
      font-size: 14px;
      line-height: 1.6;
      margin: 10px 0;
    }

    /* Card */
    .box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      padding: 16px;
      border-radius: 8px;
      margin: 20px 0;
    }

    .box p {
      margin: 6px 0;
      font-size: 13px;
    }

    /* CTA */
    .btn {
      display: inline-block;
      padding: 12px 18px;
      background: #2563eb;
      color: #ffffff;
      text-decoration: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      margin-top: 15px;
    }

    /* Footer */
    .footer {
      text-align: center;
      font-size: 12px;
      color: #94a3b8;
      padding: 20px;
      border-top: 1px solid #e2e8f0;
    }

  </style>
</head>

<body>
  <div class="container">

    <!-- Header -->
    <div class="header">
      <div class="brand">Blitz Analyzer</div>
      <div class="tagline">Ultimate Resume Builder</div>
    </div>

    <!-- Content -->
    <div class="content">

      <div class="success-badge">Payment Successful</div>

      <h2>Your payment is confirmed</h2>

      <p>Hi <strong><%= user.name %></strong>,</p>

      <p>
        Your payment has been successfully processed. Your credits are now available and you can continue building and downloading your resume without interruption.
      </p>

      <!-- Payment Details -->
      <div class="box">
        <p><strong>Transaction ID:</strong> <%= transactionId %></p>
        <p><strong>Amount Paid:</strong> $ <%= amount %></p>
        <p><strong>Credits Added:</strong> <%= credit %></p>
      </div>

      <p>
        Access your dashboard to continue editing or download your resume.
      </p>

      <!-- CTA -->
      <a href="<%= dashboardUrl %>" class="btn">
        Open Dashboard
      </a>

      <p style="margin-top: 25px;">
        Need help? Our support team is always here for you.
      </p>

      <p>
        — Blitz Analyzer Team
      </p>
      <p>
       Founder — HabiburRhaman - Software Enginner
      </p>

    </div>

    <!-- Footer -->
    <div class="footer">
      © <%= new Date().getFullYear() %> Blitz Analyzer. All rights reserved.
    </div>

  </div>
</body>
</html>